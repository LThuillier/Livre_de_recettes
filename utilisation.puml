@startuml
left to right direction
skinparam packageStyle rectangle
skinparam usecase {
    BackgroundColor LightCyan
    BorderColor DarkCyan
    ArrowColor DimGray
}
skinparam actor {
    BackgroundColor LightBlue
    BorderColor DarkBlue
}

actor "Utilisateur" as U

rectangle "Les recettes de Lima (Application Flutter)" {
  usecase "Consulter la liste des recettes" as UC_Consulter
  usecase "Filtrer les recettes par catégorie" as UC_Filtrer
  usecase "Ajouter une nouvelle recette" as UC_Ajouter
  usecase "Modifier une recette existante" as UC_Modifier
  usecase "Supprimer une recette" as UC_Supprimer
  usecase "Générer le planning de la semaine" as UC_Planning
  usecase "Actualiser aléatoirement un repas" as UC_Actualiser
}

' Liaisons principales avec l'utilisateur
U --> UC_Consulter
U --> UC_Ajouter
U --> UC_Modifier
U --> UC_Supprimer
U --> UC_Planning

' Inclusions / Extensions (Optionnelles mais très bien vues pour le BTS)
UC_Consulter <.. UC_Filtrer : <<extend>>
UC_Planning <.. UC_Actualiser : <<extend>>

@enduml