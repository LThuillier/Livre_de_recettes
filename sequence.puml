@startuml
title Diagramme de Séquence : Création d'une Recette (Admin)
autonumber

actor "Administrateur" as Admin
boundary "Vue : recettes.create" as Vue
control "RecetteController" as Ctrl
entity "Recette (Model)" as Model
database "Base de données" as BDD

Admin -> Vue : Remplit le formulaire (titre, ingrédients, etc.)
Admin -> Vue : Clique sur "Enregistrer"
Vue -> Ctrl : POST /recettes (Request $request)

activate Ctrl
Ctrl -> Ctrl : Valide les données (RecetteRequest)

note right of Ctrl
  Vérification de l'email
  (adminrecette@gmail.com)
  pour fixer est_public = true
end note

Ctrl -> Model : create($data)
activate Model
Model -> BDD : INSERT INTO recettes
BDD --> Model : OK (id_recette)
deactivate Model

loop pour chaque ingrédient
    Ctrl -> Ctrl : syncIngredients()
    Ctrl -> BDD : INSERT INTO recette_ingredient (pivot)
end

Ctrl --> Vue : Redirect avec Success Message
deactivate Ctrl

Vue --> Admin : Affiche la liste des recettes
@enduml